# Database
DATABASE_URL="postgresql://username:password@localhost:5432/kondo_db"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Google OAuth (Required for authentication)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# OpenAI API (Required for GPT responses)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Supabase (Optional - for enhanced search functionality)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ElevenLabs (Optional - for text-to-speech)
ELEVENLABS_API_KEY="your-elevenlabs-api-key"

# Amplitude Analytics (Optional - for usage analytics)
NEXT_PUBLIC_AMPLITUDE_API_KEY="your-amplitude-api-key"

# Stripe (Required for premium subscriptions)
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
# Get this from: https://dashboard.stripe.com/apikeys (Publishable key)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
# Get this from: Dashboard → Products → [Your Product] → Pricing → price_xxx
# NOTE: This must be a Price ID (price_xxx), NOT a Product ID (prod_xxx)
STRIPE_PREMIUM_PRICE_ID="price_..."
# Get this from: Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."
